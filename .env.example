# ============================================================
# ChurnShield MLOps Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- MLflow Configuration ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ChurnShield
MLFLOW_MODEL_NAME=ChurnShield-Model
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# --- Database (PostgreSQL for MLflow backend) ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_password
POSTGRES_DB=mlflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Prefect Configuration ---
PREFECT_API_URL=http://localhost:4200/api
PREFECT_UI_URL=http://localhost:4200

# --- FastAPI Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=INFO

# --- Data Paths ---
RAW_DATA_PATH=data/raw/telco_churn.csv
PROCESSED_DATA_PATH=data/processed/telco_churn_processed.csv
REFERENCE_DATA_PATH=data/reference/reference_dataset.csv
MODELS_PATH=models/

# --- Monitoring ---
DRIFT_REPORT_PATH=monitoring/reports/
DRIFT_THRESHOLD=0.3

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- Docker Registry ---
REGISTRY=ghcr.io
IMAGE_NAME=your-github-username/churnshield-mlops
IMAGE_TAG=latest

# --- AWS S3 (optional, for DVC remote) ---
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
DVC_REMOTE_URL=s3://your-bucket/churnshield-dvc
