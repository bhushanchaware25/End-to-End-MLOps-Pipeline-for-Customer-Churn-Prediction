# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Testing & Coverage ---
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/

# --- MLflow ---
mlruns/
mlartifacts/

# --- DVC ---
/tmp

# --- Data (large files tracked by DVC) ---
data/raw/*.csv
data/processed/*.csv
data/reference/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/reference/.gitkeep

# --- Models ---
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth

# --- Monitoring Reports ---
monitoring/reports/*.html
monitoring/reports/*.json

# --- Docker ---
.docker/

# --- Node / Frontend ---
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.*.local

# --- Logs ---
logs/
*.log

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
